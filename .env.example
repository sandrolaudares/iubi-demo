# ==== Gateway das APIs IUBI ====
# O frontend chama /iubi/* (mesma origem) e o servidor Express repassa para este
# upstream — evita mixed-content (HTTPS->HTTP) e CORS.
IUBI_UPSTREAM=http://100.52.200.210:32200
# (Opcional) Forçar o frontend a chamar o gateway direto, ignorando o proxy.
# Deixe vazio para usar o proxy /iubi (recomendado).
# VITE_IUBI_BASE_URL=

# (Opcional) Proxy HTTP de saída para alcançar a rede privada do gateway.
# Em produção no Fly, é setado automaticamente quando TAILSCALE_AUTHKEY existe.
# OUTBOUND_HTTP_PROXY=
# Auth key do Tailscale (só em produção/containers que precisam da rede privada).
# TAILSCALE_AUTHKEY=

# ==== Assistente de IA (IUBI Copilot) - servidor Express -> Groq/OpenAI-compat ====
# Chave da Groq (tier gratuito). NUNCA versione este valor.
GROQ_API_KEY=

# Endpoint compatível com OpenAI. Padrão: Groq.
OPENAI_BASE_URL=https://api.groq.com/openai/v1
# Modelo aberto padrão (Llama). Alternativas: llama-3.3-70b-versatile, openai/gpt-oss-20b
AI_MODEL=llama-3.1-8b-instant

# Porta do servidor de API/produção
PORT=8787
